# Copy to .env and adjust. docker-compose reads these automatically.

# --- Frontend (Google Maps) ---
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_MAP_ID=

# --- The single public port for the whole app (frontend + API + WebSocket) ---
APP_PORT=8080
# The URL the browser loads the app from (used for CORS). Match APP_PORT.
PUBLIC_URL=http://localhost:8080

# --- Postgres ---
POSTGRES_DB=wattwise
POSTGRES_USER=wattwise_user
POSTGRES_PASSWORD=wattwise_pass

# --- Simulator / Bridge ---
METER_ID=NXM-001-TZN

# --- Local Arduino bridge (NOT run in Docker; run on the laptop with the UNO) ---
# This is the ONLY thing you change to switch from simulator to real hardware.
# Point it at the same single public port the rest of the stack uses:
#   API_BASE=http://localhost:8080/api   (or https://your-host/api when deployed)
#   SERIAL_PORT=COM3
