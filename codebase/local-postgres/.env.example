# Copy this file to .env and adjust as needed:  cp .env.example .env
# These are the LOCAL TEST database credentials. Do not use in production.

POSTGRES_USER=wattwise
POSTGRES_PASSWORD=change_me
POSTGRES_DB=wattwise_test

# Host port to expose Postgres on (change if 5432 is already in use).
POSTGRES_PORT=5432

TZ=Africa/Johannesburg

DATABASE_URL=postgresql://wattwise:change_me@localhost:5432/wattwise_test
